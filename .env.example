# =============================================================================
# Application
# =============================================================================

# The port the HTTP server listens on.
# Used by: main.ts → app.listen(PORT)
PORT=3000

# Runtime environment. Controls log verbosity, CSP strictness, and whether Swagger UI is mounted.
# Values: development | staging | production
# Used by: @interloid/logger (level), @interloid/security (HSTS, secure cookies)
NODE_ENV=development

# Upstream URL context used to map absolute URLs across callbacks and templates.
EXTERNAL_URL=http://localhost:3000

# The absolute number of upstream proxy hops (e.g., Nginx, Cloudflare) to trust for client IP determination.
TRUST_PROXY_DEPTH=1


# =============================================================================
# Logging — @interloid/logger
# =============================================================================

# Pino log level. In production set to 'info' or higher; 'debug' is very chatty.
# Values: trace | debug | info | warn | error | fatal
LOG_LEVEL=debug

# System output structure style for stream targets.
# Values: json | pretty
LOG_FORMAT=pretty

# Whether to pretty-print logs for human readability. Disable in production so log aggregators get clean JSON.
# Type: boolean (true/false)
LOG_PRETTY=true

# Toggles whether logs should be synchronously piped to standard stdout streams alongside file transports.
LOG_ALSO_STDOUT=true

# The filesystem path directory where write streams write local log archives.
LOG_DIRECTORY=./logs

# Number of standard days to preserve persistent tracking data logs before automatic rotation wipes them.
LOG_RETENTION_DAYS=7


# =============================================================================
# CORS — @interloid/security
# =============================================================================

# Comma-separated list of exact allowed origins. Leave empty to disable.
# Example: https://app.interloid.com,https://admin.interloid.com
CORS_ORIGINS=http://localhost:3001

# Regex pattern for dynamic subdomains. 
# Example: ^https://.+\.interloid\.com$
CORS_PATTERN=


# =============================================================================
# Throttler — @interloid/security
# =============================================================================

# Maximum requests per IP within THROTTLER_TTL_MS. Default in starter: 100.
# Used by: @interloid/security GLOBAL_THROTTLER_PRESET
# Type: number
THROTTLER_LIMIT=100

# Throttler window in milliseconds. 60_000 = 1 minute.
# Type: number
THROTTLER_TTL_MS=60000


# =============================================================================
# CSRF — @interloid/security [OPTIONAL]
# =============================================================================

# Enable CSRF protection. Only needed for cookie-based session auth. Bearer-token APIs do NOT need this.
# Type: boolean (true/false)
CSRF_ENABLED=false

# Bound host network namespace context for tracking validation state cookies.
# Example: .yourdomain.com
CSRF_COOKIE_DOMAIN=localhost

# Context ruleset defining cookie exposure criteria across cross-site boundaries.
# Values: lax | strict | none
CSRF_SAME_SITE=lax


# =============================================================================
# Infrastructure & Third-Party Services
# =============================================================================

# Connection connection URL string for the Redis cache/state store instance.
# Format: redis://[user]:[password]@[host]:[port]
REDIS_URL=redis://localhost:6379

# The DSN ingestion endpoint address linked to your Sentry dashboard project panel.
SENTRY_DSN=

# The percentage allocation rate tracking transactions dispatched to Sentry dashboard panels.
# Example: 0.1 tracks 10% of total application requests
SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry Protocol (OTLP) gRPC/HTTP endpoint address for distributed tracking collectors.
# Leave commented out locally unless running an active collector container setup (Jaeger, Promtail).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317


# =============================================================================
# Systems Observability & Health Indicators
# =============================================================================

# Percent limit boundary triggering alerts when volume storage exceeds thresholds.
# Example: 0.8 handles alerts at 80% full usage layout metrics.
HEALTH_DISK_THRESHOLD=0.8

# V8 virtual engine heap memory upper allocation cap boundary defined in Bytes.
# Example: 536870912 equals 512MB
HEALTH_MEMORY_HEAP_MB=536870912